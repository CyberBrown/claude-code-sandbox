# Local development environment variables
# Copy to .dev.vars and fill in values

# Anthropic API key for Claude Code execution
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Cloudflare API Token for `wrangler deploy` and `wrangler secret put`
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Workers Scripts:Edit, Workers Containers:Edit
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
