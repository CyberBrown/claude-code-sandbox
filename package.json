{
  "name": "claude-code-sandbox",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Run Claude Code headless on Cloudflare Sandbox SDK",
  "scripts": {
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "deploy": "export $(grep -v '^#' .dev.vars 2>/dev/null | xargs) && wrangler deploy",
    "secret:put": "export $(grep -v '^#' .dev.vars 2>/dev/null | xargs) && wrangler secret put",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.6.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251230.0",
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "wrangler": "^4.54.0"
  },
  "license": "Apache-2.0"
}
